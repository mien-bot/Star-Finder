# Star Finder Environment Variables
# Copy this file to .env.local and fill in your API keys

# =============================================
# REQUIRED API KEYS
# =============================================

# OpenAI GPT-4o (for AI fallback star identification)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Astrometry.net (for plate solving / star identification)
# Get key: https://nova.astrometry.net (create account, find API key in profile)
ASTROMETRY_API_KEY=

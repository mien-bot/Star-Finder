# HYLO-SP Environment Variables
# Copy this file to .env.local and fill in your API keys

# =============================================
# VISION API KEYS (Optional - app works without)
# =============================================

# Option 1: OpenAI GPT-4V (recommended)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Option 2: Anthropic Claude Vision
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Option 3: Google Gemini Vision
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# =============================================
# APP CONFIG (Optional)
# =============================================

# App URL (for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================
# BLENDER CONFIG (Future - for server-side rendering)
# =============================================

# Path to Blender executable (optional)
# BLENDER_PATH=/usr/bin/blender
